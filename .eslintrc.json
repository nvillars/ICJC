{
  "root": true,
  "extends": ["next/core-web-vitals", "eslint:recommended"],
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "globals": {
    "React": "readonly"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "warn"
  }
}
